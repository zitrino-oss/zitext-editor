{
  "productName": "ZITEXT Editor",
  "version": "2.1.5",
  "identifier": "com.zitrino.zitext",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZITEXT Editor",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self' ipc: https://ipc.localhost https://zitext.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.sectigo.com",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "English"
        ],
        "template": null
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ]
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "txt"
        ],
        "name": "Plain Text File",
        "description": "Plain text document",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown File",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "ext": [
          "json"
        ],
        "name": "JSON File",
        "description": "JSON data file",
        "role": "Editor",
        "mimeType": "application/json"
      },
      {
        "ext": [
          "xml"
        ],
        "name": "XML File",
        "description": "XML document",
        "role": "Editor",
        "mimeType": "application/xml"
      },
      {
        "ext": [
          "yaml",
          "yml"
        ],
        "name": "YAML File",
        "description": "YAML configuration file",
        "role": "Editor",
        "mimeType": "application/x-yaml"
      },
      {
        "ext": [
          "html",
          "htm"
        ],
        "name": "HTML File",
        "description": "HTML document",
        "role": "Editor",
        "mimeType": "text/html"
      },
      {
        "ext": [
          "css"
        ],
        "name": "CSS File",
        "description": "Cascading Style Sheet",
        "role": "Editor",
        "mimeType": "text/css"
      },
      {
        "ext": [
          "js",
          "mjs",
          "cjs",
          "jsx"
        ],
        "name": "JavaScript File",
        "description": "JavaScript source code",
        "role": "Editor",
        "mimeType": "text/javascript"
      },
      {
        "ext": [
          "ts",
          "tsx",
          "mts",
          "cts"
        ],
        "name": "TypeScript File",
        "description": "TypeScript source code",
        "role": "Editor",
        "mimeType": "text/typescript"
      },
      {
        "ext": [
          "scss",
          "sass",
          "less"
        ],
        "name": "CSS Preprocessor File",
        "description": "SCSS/Sass/Less stylesheet",
        "role": "Editor",
        "mimeType": "text/css"
      },
      {
        "ext": [
          "py"
        ],
        "name": "Python File",
        "description": "Python source code",
        "role": "Editor",
        "mimeType": "text/x-python"
      },
      {
        "ext": [
          "java"

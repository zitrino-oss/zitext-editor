        ],
        "name": "Batch Script",
        "description": "Windows batch script",
        "role": "Editor",
        "mimeType": "text/x-batch"
      },
      {
        "ext": [
          "tex",
          "sty",
          "cls"
        ],
        "name": "LaTeX File",
        "description": "LaTeX document",
        "role": "Editor",
        "mimeType": "text/x-latex"
      },
      {
        "ext": [
          "toml"
        ],
        "name": "TOML File",
        "description": "TOML configuration file",
        "role": "Editor",
        "mimeType": "application/toml"
      },
      {
        "ext": [
          "ini",
          "conf",
          "cfg"
        ],
        "name": "Configuration File",
        "description": "Configuration file",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": [
          "log"
        ],
        "name": "Log File",
        "description": "Log file",
        "role": "Viewer",
        "mimeType": "text/plain"
      },
      {
        "ext": [
          "csv"
        ],
        "name": "CSV File",
        "description": "Comma-separated values",
        "role": "Editor",
        "mimeType": "text/csv"
      }
    ]
  }
}

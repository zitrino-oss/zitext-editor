{
  "name": "zitext-editor",
  "private": true,
  "version": "2.1.4",
  "description": "A fast, lightweight, cross-platform text and code editor built with Tauri and Monaco.",
  "author": "Zitrino",
  "license": "Apache-2.0",
  "homepage": "https://zitext.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/zitrino-oss/zitext-editor.git"
  },
  "bugs": {
    "url": "https://github.com/zitrino-oss/zitext-editor/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13 <23"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "tauri": "tauri",
    "bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "dompurify": "^3.4.11",
    "github-markdown-css": "^5.9.0",
    "jsonc-parser": "^3.3.1",
    "marked": "^18.0.7",
    "monaco-editor": "^0.56.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^26.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^3.2.7"
  }
